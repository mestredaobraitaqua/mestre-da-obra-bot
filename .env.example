# =============================================================
# CONFIGURAÇÕES DO BOT - MESTRE DA OBRA
# Copie este arquivo para ".env" e preencha os valores reais
# NUNCA envie o arquivo .env para o GitHub!
# =============================================================

# --- ANTHROPIC (IA) ---
# Encontre em: console.anthropic.com > API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# --- WHATSAPP (META) ---
# Encontre em: developers.facebook.com > seu app > WhatsApp > Configuração
WHATSAPP_PHONE_NUMBER_ID=000000000000000
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxx
WHATSAPP_VERIFY_TOKEN=mestre_da_obra_bot_2024

# --- SUPABASE (BANCO DE DADOS) ---
# Encontre em: supabase.com > seu projeto > Settings > API
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxx

# --- SERVIDOR ---
PORT=3000
